# Google Gemini API Key (required for original 120–180 word summaries)
# Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Copyright-free images: Unsplash (primary), Pexels (fallback). No AI-generated images.
# Without these, a local fallback image is used for all articles.
UNSPLASH_ACCESS_KEY=your_unsplash_key_here
PEXELS_API_KEY=your_pexels_key_here
